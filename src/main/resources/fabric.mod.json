{
	"schemaVersion": 1,
	"id": "burvy-zombie-mod",
	"version": "${version}",
	"name": "Burvy Zombie Mod",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/burvy-zombie-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "burvy.BurvyZombieMod",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "burvy.BurvyZombieModClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "burvy.BurvyZombieModDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"burvy-zombie-mod.mixins.json",
		{
			"config": "burvy-zombie-mod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}